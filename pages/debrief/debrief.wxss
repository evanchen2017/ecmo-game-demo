/* pages/debrief/debrief.wxss */
page {
  background-color: #F0F4F8;
  height: 100%;
}

.container {
  display: flex;
  flex-direction: column;
  height: 100%;
  padding: 20rpx;
  box-sizing: border-box;
}

.custom-nav {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background-color: white;
  padding-left: 20px;
  padding-right: 20px;
  padding-bottom: 12px;
  border-radius: 60rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.nav-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1E293B;
}

.total-score {
  background-color: #10B981;
  color: white;
  padding: 6rpx 20rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.patient-info {
  background-color: white;
  border-radius: 32rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  display: flex;
  justify-content: space-between;
  font-size: 26rpx;
  color: #475569;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.swiper {
  flex: 1;
  background-color: white;
  border-radius: 32rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

.tab-content {
  padding: 30rpx;
  height: 100%;
  box-sizing: border-box;
}

.chart-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 30rpx;
  color: #0F172A;
}

.score-chart {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
  margin-bottom: 40rpx;
}

.chart-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.level-name {
  width: 100rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: #334155;
}

.bar-container {
  flex: 1;
  height: 40rpx;
  background-color: #E2E8F0;
  border-radius: 20rpx;
  overflow: hidden;
}

.bar {
  height: 100%;
  width: 0%;
  background-color: #10B981;
  transition: width 0.3s;
}

.score-number {
  width: 60rpx;
  text-align: right;
  font-size: 28rpx;
  font-weight: 600;
  color: #0F172A;
}

.overall-rating {
  background-color: #F1F5F9;
  padding: 20rpx;
  border-radius: 24rpx;
  text-align: center;
  font-size: 28rpx;
  color: #1E293B;
  margin-top: 20rpx;
}

.error-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.error-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background-color: #FEF2F2;
  padding: 20rpx;
  border-radius: 20rpx;
  border-left: 8rpx solid #EF4444;
}

.error-icon {
  font-size: 36rpx;
}

.error-text {
  flex: 1;
  font-size: 28rpx;
  color: #7F1D1D;
  line-height: 1.4;
}

.empty-tip {
  text-align: center;
  font-size: 32rpx;
  color: #10B981;
  padding: 60rpx 0;
}

.report-box {
  background-color: #F8FAFE;
  border-radius: 24rpx;
  padding: 30rpx;
}

.report-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
  color: #1E293B;
}

.report-text {
  display: block;
  font-size: 28rpx;
  line-height: 1.6;
  color: #334155;
  white-space: pre-wrap;
  margin-bottom: 30rpx;
}

.copy-btn {
  background-color: #3B82F6;
  color: white;
  border-radius: 40rpx;
  font-size: 28rpx;
  height: 80rpx;
  line-height: 80rpx;
}

.bottom-buttons {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
}

.reset-btn, .finish-btn {
  flex: 1;
  height: 96rpx;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
}

.reset-btn {
  background-color: #F1F5F9;
  color: #475569;
  border: 2rpx solid #CBD5E1;
}

.finish-btn {
  background-color: #10B981;
  color: white;
  box-shadow: 0 8rpx 20rpx rgba(16,185,129,0.3);
}

/* 证书模态框 */
.cert-modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0,0,0,0.7);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
}

.cert-content {
  width: 640rpx;
  background-color: white;
  border-radius: 32rpx;
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.cert-canvas {
  width: 560rpx;
  height: 720rpx;
  margin-bottom: 30rpx;
  border-radius: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.2);
}

.cert-buttons {
  display: flex;
  gap: 20rpx;
  width: 100%;
}

.save-btn, .close-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.save-btn {
  background-color: #3B82F6;
  color: white;
}

.close-btn {
  background-color: #94A3B8;
  color: white;
}