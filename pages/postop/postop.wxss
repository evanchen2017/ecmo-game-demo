/* pages/postop/postop.wxss */
page {
  background-color: #E6EDF4;
  height: 100%;
}

.container {
  display: flex;
  flex-direction: column;
  height: 100%;
  padding: 20rpx;
  box-sizing: border-box;
}

.custom-nav {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background-color: white;
  padding-left: 20px;
  padding-right: 20px;
  padding-bottom: 12px;
  border-radius: 60rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.nav-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1E293B;
}

.nav-right {
  display: flex;
  gap: 24rpx;
  align-items: center;
}

.risk-counter, .score {
  background-color: #F1F5F9;
  padding: 6rpx 16rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  color: #0F172A;
}

.hint-icon {
  font-size: 40rpx;
  background-color: #F1F5F9;
  width: 60rpx;
  height: 60rpx;
  line-height: 60rpx;
  text-align: center;
  border-radius: 50%;
}

.scene {
  position: relative;
  background-color: #CBD5E1;
  border-radius: 32rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  flex-shrink: 0;
}

.scene-bg {
  position: absolute;
  width: 100%;
  height: 100%;
  background: linear-gradient(145deg, #A0C4E0, #7BA3C0);
  z-index: 0;
}

/* 模拟图形元素 */
.patient-body {
  position: absolute;
  width: 40%;
  height: 45%;
  background-color: #F4C2A5;
  bottom: 20%;
  left: 30%;
  border-radius: 40% 40% 30% 30%;
  z-index: 1;
}

.patient-head {
  position: absolute;
  width: 18%;
  height: 18%;
  background-color: #F4C2A5;
  top: 15%;
  left: 41%;
  border-radius: 50%;
  z-index: 1;
}

.patient-arm {
  position: absolute;
  width: 12%;
  height: 20%;
  background-color: #F4C2A5;
  top: 35%;
  right: 22%;
  border-radius: 30%;
  transform: rotate(20deg);
  z-index: 1;
}

.patient-leg {
  position: absolute;
  width: 12%;
  height: 25%;
  background-color: #F4C2A5;
  bottom: 10%;
  left: 33%;
  border-radius: 30%;
  z-index: 1;
}

.cannulation-site {
  position: absolute;
  width: 8%;
  height: 10%;
  background-color: #CD5C5C;
  bottom: 28%;
  left: 41%;
  border-radius: 40%;
  z-index: 2;
}

.ecmo-machine {
  position: absolute;
  width: 22%;
  background-color: #2C3E50;
  color: #ECF0F1;
  font-size: 20rpx;
  padding: 12rpx;
  border-radius: 16rpx;
  top: 10%;
  right: 5%;
  z-index: 2;
  text-align: center;
}

.monitor {
  position: absolute;
  width: 25%;
  background-color: #1C2833;
  color: #00FFCC;
  font-size: 20rpx;
  padding: 12rpx;
  border-radius: 16rpx;
  top: 40%;
  left: 5%;
  z-index: 2;
}

.urine-bag {
  position: absolute;
  width: 12%;
  background-color: #D5DBDB;
  color: #17202A;
  font-size: 20rpx;
  padding: 8rpx;
  border-radius: 12rpx;
  bottom: 5%;
  right: 8%;
  z-index: 2;
  text-align: center;
}

/* 热区公共样式 */
.hotspot {
  position: absolute;
  background-color: rgba(255, 0, 0, 0);
  border: 2rpx solid rgba(255, 0, 0, 0);
  border-radius: 50%;
  width: 60rpx;
  height: 60rpx;
  z-index: 10;
  transition: all 0.2s;
}

/* 闪烁效果（红色边框闪烁） */
.hotspot.flash {
  border: 4rpx solid #EF4444;
  background-color: rgba(239, 68, 68, 0.3);
  animation: blink 1s infinite;
}

@keyframes blink {
  0% { opacity: 0.4; }
  50% { opacity: 1; }
  100% { opacity: 0.4; }
}

/* 已解决热区显示绿色对勾 */
.hotspot.resolved::after {
  content: "✓";
  position: absolute;
  top: 10rpx;
  left: 10rpx;
  font-size: 40rpx;
  color: #10B981;
  font-weight: bold;
}

/* 各热区位置（基于375px宽度的设计，实际屏幕会自动缩放） */
.hotspot-1 { top: 25%; left: 55%; }  /* 管路气泡 */
.hotspot-2 { top: 70%; left: 30%; }  /* 左下肢 */
.hotspot-3 { top: 55%; left: 40%; }  /* 插管处 */
.hotspot-4 { top: 80%; right: 12%; } /* 尿袋 */
.hotspot-5 { top: 45%; left: 47%; }  /* 心前区 */
.hotspot-6 { top: 12%; right: 15%; } /* 膜肺压力 */

.bottom-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background-color: white;
  padding: 20rpx 30rpx;
  border-radius: 60rpx;
  margin-top: auto;
}

.clicked-info {
  font-size: 28rpx;
  color: #475569;
}

.info-btn {
  background-color: #3B82F6;
  color: white;
  border-radius: 40rpx;
  font-size: 28rpx;
  padding: 12rpx 32rpx;
}

/* 模态框 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0,0,0,0.5);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 200;
}

.modal-container {
  width: 80%;
  background-color: white;
  border-radius: 32rpx;
  padding: 40rpx;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.modal-timer {
  color: #EF4444;
}

.modal-progress {
  height: 8rpx;
  background-color: #E2E8F0;
  border-radius: 4rpx;
  margin-bottom: 30rpx;
  overflow: hidden;
}

.modal-progress-fill {
  height: 100%;
  width: 100%;
  background-color: #EF4444;
  transition: width 0.1s linear;
}

.modal-question {
  font-size: 32rpx;
  margin-bottom: 40rpx;
}

.modal-options {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.modal-option {
  background-color: #F1F5F9;
  padding: 20rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
}